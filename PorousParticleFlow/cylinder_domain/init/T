FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    sides
    {
        type            fixedValue;
        value           uniform 950;
    }
    inlet
    {
        type            fixedValue;
        value           uniform 840;
    }
    outlet
    {
        type            zeroGradient;
    }
}


