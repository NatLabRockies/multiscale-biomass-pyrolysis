FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{

    "(rho|rhoFinal)"
    {
        solver              diagonal;
    };
    
    p
    {
        solver          GAMG;
        smoother       DIC;
        tolerance       1e-08;
      //  relTol          0.01;

    }

    pFinal
    {
        $p
        relTol          0;

    }


    p_rgh
    {
        solver          PCG;
        smoother       DIC;
        preconditioner DIC
        tolerance       1e-08;
        //relTol          0.05;

    }

    p_rghFinal
    {
        $p_rgh
        relTol          0;

    }

    "(U|k|epsilon|T|Yi|h).*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-07;
        relTol          0;
    }

    "T.solid.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0.05;
        smoother        GaussSeidel;
        nCellsInCoarsestLevel 20;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;
    nCorrectors 10;
}

relaxationFactors
{
/*    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        k               0.9;
        epsilon         0.9;
    } */
}


