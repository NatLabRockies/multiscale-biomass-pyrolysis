FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "${FOAM_CASE}/constant/globalVars"
castellatedMesh true;
snap            false;
//snap            false;
addLayers       false;

geometry
{
    particle
    {
        type searchableCylinder;
        point1 ($xmid $ymid $cylbotz);
        point2 ($xmid $ymid $cyltopz);
        radius $cylrad;
    }
    
}


castellatedMeshControls
{

    maxLocalCells 100000;

    maxGlobalCells 2000000;

    minRefinementCells 0;

    nCellsBetweenLevels 4;

    maxLoadUnbalance 0.10;

    features
    (

    );

    resolveFeatureAngle 30;

    refinementSurfaces
    {
        particle
        {
         // change this to have higher resolution at surface of particle
            level (1 1);
            cellZone cellParticleZone;
            faceZone faceParticleZone;
            mode        inside;
        }
    }

    refinementRegions
    {
    // change this to have higher resolution inside particle
        particle
        {
            mode inside;
            levels ((1 1));
        }
        
    }

    locationInMesh (0.01 0.01 0.0); // Inside point

    allowFreeStandingZoneFaces true;
}

// Settings for the snapping.
snapControls
{

    nSmoothPatch 3;

    tolerance 1.0;

    nSolveIter 300;

    nRelaxIter 10;

    nFeatureSnapIter 10;

    implicitFeatureSnap true;

    explicitFeatureSnap false;

    multiRegionFeatureSnap true;
}

// Settings for the layer addition.
addLayersControls
{

    relativeSizes true;

    layers
    {
    }

    expansionRatio 1.0;

    finalLayerThickness 0.3;

    minThickness 0.25;

    nGrow 0;

    featureAngle 30;

    nRelaxIter 5;

    nSmoothSurfaceNormals 1;

    nSmoothNormals 3;

    nSmoothThickness 10;

    maxFaceThicknessRatio 0.5;

    maxThicknessToMedialRatio 0.3;

    minMedianAxisAngle 90;

    nBufferCellsNoExtrude 0;

    nLayerIter 50;

    nRelaxedIter 20;
}

meshQualityControls
{
    #include "meshQualityDict"

    relaxed
    {
        maxNonOrtho 75;
    }
}

writeFlags
(
);

mergeTolerance 1E-6;


