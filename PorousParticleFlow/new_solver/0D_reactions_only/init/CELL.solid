FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      CELL.solid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "${FOAM_CASE}/constant/globalVars"

dimensions      [0 0 0 0 0 0 0];

cf0 #calc "$cellFrac*(1.0-$poro)";

internalField   uniform $cf0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value		uniform 0.;
    }

    "sides|outlet"
    {
        type            zeroGradient;
    }

}


// ************************************************************************* //
