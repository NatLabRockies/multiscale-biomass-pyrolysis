FoamFile
{
    version     9.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     porousSimpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         400;
//endTime         0.002;

//deltaT          0.0001;
deltaT          0.00005;

writeControl    runTime;

writeInterval   0.05;

purgeWrite      2;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

graphFormat     raw;

runTimeModifiable true;

functions
{
    volFieldValue1
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");

        log             true;
        writeControl    writeTime;
        writeFields     false;

        regionType      all;
        operation       volAverage;

        fields
        (
            CELL.solid
            ACELL.solid
            HCELL.solid
            AHCELL.solid
            LIG.solid
            ALIG.solid
            CHAR.solid
            TRC
            TRH
            TRL
            SGC
            SGH
            SGL
        );
    }

}

