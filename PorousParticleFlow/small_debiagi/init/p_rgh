FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    outlet
    {
        type            fixedValue;
        value           $internalField;
    }
    
    "sides|upperWall"
    {
        type            fixedFluxPressure;
        value           $internalField;
    }

    defaultFaces
    {
    	type empty;
    }

    inlet
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
}


